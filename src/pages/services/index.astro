---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { getCollection } from 'astro:content';

const services = await getCollection('services');
const creativeTech = services.filter(s => s.data.category === 'Creative Tech');
const eventProd = services.filter(s => s.data.category === 'Event Production');
const environment = services.filter(s => s.data.category === 'Environment');

const serviceIcons: Record<string, string> = {
  'creative-technology': '💡',
  'event-production': '🎪',
  'event-structures': '🏗️',
  'event-decoration': '🎨',
  'audio-visual-lighting': '🔊',
  'environment': '🌿',
};
---

<Layout title="Our Services" description="Explore AS Creative's comprehensive end-to-end solutions integrating creativity, technology, events, and sustainability.">
  <Hero
    eyebrow="Our Capabilities"
    title="Service Catalogue"
    subtitle="Comprehensive end-to-end solutions integrating creativity, technology, events, and sustainability across Malaysia."
    badges={['Event Production', 'Creative & Tech', 'Environment']}
  />

  <div class="page-content">
    <section class="section" id="event-production">
      <div class="container">
        <header class="section-header fade-in-up">
          <div class="section-label">Pillar 01</div>
          <h2>Event & Experiential Services</h2>
          <p>From architectural structures and stages to high-end AV and full event management. We handle the production so you can focus on the audience.</p>
        </header>
        <div class="services-grid">
          {eventProd.map((service, index) => (
            <ServiceCard
              title={service.data.title}
              description={service.data.description}
              icon={serviceIcons[service.id] ?? '🎯'}
              link={`/services/${service.id}`}
              class={`delay-${(index % 4) + 1}`}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="creative-tech">
      <div class="container">
        <header class="section-header fade-in-up">
          <div class="section-label">Pillar 02</div>
          <h2>Creative & Technology</h2>
          <p>Cutting-edge web development, multimedia, and digital marketing solutions. Leveraging the latest digital tools to transform brand presence.</p>
        </header>
        <div class="services-grid">
          {creativeTech.map((service, index) => (
            <ServiceCard
              title={service.data.title}
              description={service.data.description}
              icon={serviceIcons[service.id] ?? '💡'}
              link={`/services/${service.id}`}
              class={`delay-${(index % 4) + 1}`}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="environment">
      <div class="container">
        <header class="section-header fade-in-up">
          <div class="section-label">Pillar 03</div>
          <h2>Environmental Services</h2>
          <p>Professional public cleansing and facilities management with a firm commitment to sustainability and global environmental standards.</p>
        </header>
        <div class="services-grid">
          {environment.map((service, index) => (
            <ServiceCard
              title={service.data.title}
              description={service.data.description}
              icon={serviceIcons[service.id] ?? '🌿'}
              link={`/services/${service.id}`}
              class={`delay-${(index % 4) + 1}`}
            />
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .page-content { position: relative; z-index: 10; padding-top: 2rem; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  .section-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-heading);
    background: linear-gradient(135deg, white, var(--primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-header p {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.75;
    max-width: 750px;
    margin-bottom: 3.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .section-header h2 { font-size: 2rem; }
  }
</style>

---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map(service => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout title={service.data.title}>
  <Hero
    eyebrow={service.data.category}
    title={service.data.title}
    subtitle="Delivering excellence and reliability through integrated solutions and professional expertise."
    badges={['Expert Implementation', 'Custom Solutions', '24/7 Support']}
  />

  <div class="page-content">
    <section class="section" id="service-detail">
      <div class="container container-padding">
        <div class="content-grid">
          <article class="main-content fade-in-up">
            <div class="section-label">Service Overview</div>
            <h2 class="content-heading">Description</h2>
            <div class="body-text">
              <p>{service.data.description}</p>
            </div>
          </article>

          {service.data.features && service.data.features.length > 0 && (
            <aside class="features-panel glass-card fade-in-up delay-1">
              <h3 class="features-heading">
                <i data-lucide="check-circle-2" style="width: 20px; height: 20px; color: var(--primary-light);"></i>
                Key Capabilities
              </h3>
              <ul class="features-list">
                {service.data.features.map(feature => (
                  <li class="feature-item">
                    {feature}
                  </li>
                ))}
              </ul>
            </aside>
          )}
        </div>

        <div class="inquiry-cta fade-in-up glass-card">
          <div class="cta-glow"></div>
          <div class="cta-content">
            <h2 class="cta-title">Interested in this service?</h2>
            <p class="cta-subtitle">Our team is ready to discuss how we can tailor this solution to your project goals.</p>
            <a href="/contact" class="btn btn-primary">Request a Proposal</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .page-content { position: relative; z-index: 10; padding-top: 2rem; }
  .container { max-width: 1200px; margin: 0 auto; }
  .container-padding { padding: 0 2rem; }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: start;
    margin-bottom: 5rem;
  }

  .section-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .content-heading {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-main);
    margin-bottom: 1.5rem;
  }

  .body-text {
    color: var(--text-muted);
    font-size: 1.15rem;
    line-height: 1.85;
  }

  /* Right column features panel */
  .features-panel {
    padding: 2.5rem;
    position: sticky;
    top: 6rem;
  }

  .features-heading {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .feature-item {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.5;
    position: relative;
    padding-left: 1.75rem;
  }

  .feature-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 8px;
    height: 8px;
    background: var(--primary);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--primary);
  }

  /* Localized CTA Banner */
  .inquiry-cta {
    position: relative;
    padding: 5rem 2rem;
    text-align: center;
    overflow: hidden;
    border-radius: 28px;
  }
  .cta-content { position: relative; z-index: 2; }
  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 800;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, white, var(--primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .cta-subtitle {
    color: var(--text-muted);
    font-size: 1.25rem;
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-glow {
    position: absolute;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.15), transparent 70%);
    border-radius: 50%;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none; z-index: 1;
  }

  @media (max-width: 992px) {
    .content-grid { grid-template-columns: 1fr; gap: 3rem; }
    .features-panel { position: static; }
  }
</style>

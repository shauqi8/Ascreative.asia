---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('portfolio');
---

<Layout title="Portfolio" description="Discover how AS Creative bring ideas to life with flawless execution and immersive experiences through our portfolio of projects.">
  <Hero
    eyebrow="Our Work"
    title="Immersive Case Studies"
    subtitle="Discover how we bring ideas to life with flawless execution and immersive experiences across diverse industries."
    badges={['Event Production', 'Creative Tech', 'AV & Lighting']}
  />

  <div class="page-content">
    <section class="section" id="portfolio">
      <div class="container">
        <header class="section-header fade-in-up">
          <div class="section-label">Selected Work</div>
          <h2>Featured Productions</h2>
          <p>A curated selection of our most impactful events and creative productions delivering real value to brands.</p>
        </header>

        <div class="projects-grid">
          {projects.map((project, index) => (
            <ProjectCard
              title={project.data.title}
              client={project.data.client}
              description={project.data.description}
              image={project.data.image}
              class={`delay-${(index % 4) + 1}`}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Project Inquiry CTA -->
    <section class="section" id="inquiry">
      <div class="container">
        <div class="cta-banner fade-in-up glass-card">
          <div class="cta-content">
            <h2 class="cta-title">Have a project in mind?</h2>
            <p class="cta-subtitle">Let's collaborate to create your next memorable experience.</p>
            <a href="/contact" class="btn btn-primary">Start a Conversation</a>
          </div>
          <div class="cta-glow"></div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .page-content { position: relative; z-index: 10; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  .section-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  /* CTA Banner - consistent with index.astro */
  .cta-banner {
    position: relative;
    padding: 5rem 2rem;
    text-align: center;
    overflow: hidden;
    border-radius: 28px;
  }
  .cta-content { position: relative; z-index: 2; }
  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #ffffff, var(--primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .cta-subtitle {
    color: var(--text-muted);
    font-size: 1.25rem;
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-glow {
    position: absolute;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.15), transparent 70%);
    border-radius: 50%;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none; z-index: 1;
  }
</style>

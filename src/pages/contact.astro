---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Contact Us" description="Ready to start your next project? Get in touch with AS Creative Solution & Resources team today for premier integrated solutions.">
  <Hero
    eyebrow="Let's Talk"
    title="Start a Conversation"
    subtitle="Ready to elevate your brand with immersive experiences? Get in touch with our team of experts today."
    badges={['Quick Response', 'Technical Support', 'Free Consultation']}
  />

  <div class="page-content">
    <section class="section" id="contact-details">
      <div class="container">
        <div class="contact-grid">

          <!-- Contact Info -->
          <div class="contact-info fade-in-up">
            <div class="section-label">Connect With Us</div>
            <h2 class="info-heading">Reach Out Directly</h2>
            
            <div class="info-items">
              <div class="info-item glass-card">
                <div class="info-icon">📍</div>
                <div class="info-content">
                  <h4>Headquarters</h4>
                  <address>
                    Lot 14, Jalan Perusahaan Dua,<br />
                    Batu Caves Industrial Area,<br />
                    68100 Batu Caves, Selangor, Malaysia
                  </address>
                </div>
              </div>

              <div class="info-item glass-card">
                <div class="info-icon">📧</div>
                <div class="info-content">
                  <h4>Email Support</h4>
                  <a href="mailto:Adam.ascsr@gmail.com">Adam.ascsr@gmail.com</a>
                  <a href="mailto:saiful.ascsr@gmail.com">saiful.ascsr@gmail.com</a>
                  <div class="email-actions" style="margin-top: 1rem;">
                    <a href="mailto:Adam.ascsr@gmail.com,saiful.ascsr@gmail.com" class="btn btn-secondary btn-sm" style="padding: 0.5rem 1.25rem; font-size: 0.8rem;">
                      <i data-lucide="mails" style="width: 14px; height: 14px; margin-right: 6px;"></i>
                      Email Both Directly
                    </a>
                  </div>
                </div>
              </div>

              <div class="info-item glass-card">
                <div class="info-icon">📞</div>
                <div class="info-content">
                  <h4>Phone Lines</h4>
                  <div class="phone-entry">
                    <span>Adam Shah:</span>
                    <a href="tel:+60173746240">+60 17-374 6240</a>
                  </div>
                  <div class="phone-entry">
                    <span>Saiful Rizan:</span>
                    <a href="tel:+60122197979">+60 12-219 7979</a>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="contact-form-panel glass-card fade-in-up delay-1">
            <h3 class="form-heading">Send an Inquiry</h3>
            
            <div id="form-status" class="form-status hidden"></div>

            <form class="contact-form" id="contact-form">
              <!-- Hidden fields for Web3Forms -->
              <input type="hidden" name="from_name" value="AS Creative Website" />
              <input type="hidden" name="subject" value="New Inquiry from Website" />
              <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
              <div class="form-group">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" placeholder="John Doe" required />
              </div>
              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="john@example.com" required />
              </div>
              <div class="form-group">
                <label for="subject">Enquiry Subject</label>
                <input type="text" id="subject" name="subject" placeholder="Event Production Inquiry" />
              </div>
              <div class="form-group">
                <label for="message">Your Message</label>
                <textarea id="message" name="message" rows="5" placeholder="Tell us more about your project goals..." required></textarea>
              </div>
              <button type="submit" class="btn btn-primary w-full">
                Send Message
                <i data-lucide="send" style="width: 18px; height: 18px;"></i>
              </button>
            </form>
          </div>

        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .page-content { position: relative; z-index: 10; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: start;
  }

  .section-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .info-heading {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-main);
    margin-bottom: 2.5rem;
  }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-item {
    display: flex;
    gap: 1.5rem;
    padding: 2rem;
    align-items: flex-start;
  }

  .info-icon {
    font-size: 1.75rem;
    width: 50px; height: 50px;
    background: rgba(59, 130, 246, 0.1);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .info-content h4 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text-main);
  }

  .info-content address, .info-content a, .info-content .phone-entry {
    color: var(--text-muted);
    font-style: normal;
    font-size: 1rem;
    line-height: 1.6;
    display: block;
    text-decoration: none;
    transition: color var(--trans-fast);
  }

  .info-content a:hover { color: var(--primary-light); }
  
  .phone-entry span { color: var(--text-main); font-weight: 500; margin-right: 0.5rem; }
  .phone-entry a { display: inline; }

  /* Form Styling */
  .contact-form-panel { padding: 3rem; }
  .form-heading {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: var(--text-main);
  }

  .contact-form { display: flex; flex-direction: column; gap: 1.75rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.75rem; }

  .form-group label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-main);
  }

  .form-group input, .form-group textarea {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    color: var(--text-main);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: all var(--trans-fast);
    outline: none;
  }

  .form-group input:focus, .form-group textarea:focus {
    border-color: var(--primary);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
  }

  .w-full { width: 100%; }

  @media (max-width: 992px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    .contact-form-panel { padding: 2rem; }
  }

  /* Status Messages */
  .form-status {
    padding: 1rem 1.5rem;
    border-radius: 12px;
    margin-bottom: 2rem;
    font-size: 0.95rem;
    font-weight: 500;
    backdrop-filter: var(--glass-blur);
    border: 1px solid transparent;
    transition: all 0.3s ease;
  }
  .form-status.success {
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.3);
    color: #10b981;
  }
  .form-status.error {
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.3);
    color: #ef4444;
  }
  .form-status.hidden { display: none; }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const statusBox = document.getElementById('form-status');
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

    if (!form || !statusBox || !submitBtn) return;

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        formData.append("access_key", "a6059198-24ef-40bb-b57c-e4850fe5a2fc");

        const originalBtnHtml = submitBtn.innerHTML;

        // Loading State
        submitBtn.innerHTML = 'Sending Inquiry... <span class="spinner"></span>';
        submitBtn.disabled = true;
        statusBox.classList.add('hidden');

        try {
            const response = await fetch("https://api.web3forms.com/submit", {
                method: "POST",
                body: formData
            });

            const data = await response.json();

            if (response.ok) {
                statusBox.textContent = "Success! Your message has been sent to Saiful and Adam.";
                statusBox.className = "form-status success";
                form.reset();
                
                // Reset button after success
                setTimeout(() => {
                  statusBox.classList.add('hidden');
                }, 8000);
            } else {
                statusBox.textContent = "Error: " + (data.message || "Failed to send.");
                statusBox.className = "form-status error";
            }

        } catch (error) {
            statusBox.textContent = "Something went wrong. Please check your connection and try again.";
            statusBox.className = "form-status error";
        } finally {
            submitBtn.innerHTML = originalBtnHtml;
            submitBtn.disabled = false;
        }
    });
  });
</script>

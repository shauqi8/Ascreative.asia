---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Clients from '../components/Clients.astro';
import { getCollection } from 'astro:content';

const services = await getCollection('services');
const projects = await getCollection('portfolio');
const featuredServices = services.slice(0, 3);

const serviceIcons: Record<string, string> = {
  'creative-technology': '💡',
  'event-production': '🎪',
  'event-structures': '🏗️',
  'event-decoration': '🎨',
  'audio-visual-lighting': '🔊',
  'environment': '🌿',
};
---

<Layout title="Home">
  <Hero
    eyebrow="Malaysia's Premier Creative Partner"
    title="Elevating Brands through Creative Tech & Seamless Event Production"
    subtitle="AS Creative Solution & Resources — a leading integrated provider delivering immersive event experiences, innovative creative technology, and sustainable environmental services across Malaysia."
    primaryCta={{ text: 'Explore Catalogue', link: '#services' }}
    secondaryCta={{ text: 'Partner With Us', link: '#contact' }}
    badges={['20+ Years', '4 Pillars', '100% Sustainable']}
  />

  <!-- ===== ABOUT US ===== -->
  <section class="section" id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-visual fade-in-up" aria-hidden="true">
          <i data-lucide="shield-check" class="about-visual-icon"></i>
          <span class="about-visual-label">Excellence & Reliability</span>
        </div>
        <article class="about-text fade-in-up delay-1">
          <h2>About Us</h2>
          <p>With more than <strong>20 years of experience</strong>, we have built a strong reputation for excellence, innovation, and reliability across diverse industries and large-scale projects.</p>
          <p>We combine cutting-edge technology with creative expertise to deliver immersive experiences that connect audiences and elevate brand impact. From concept design to seamless execution, our professionals manage every detail.</p>
          <p>Our commitment to <strong>environmental stewardship</strong> drives us to implement sustainable practices across all our work, providing tailored solutions aligned with global standards.</p>
          <div class="about-stats">
            <div class="stat-item">
              <h4>20+</h4>
              <p>Years Industry Experience</p>
            </div>
            <div class="stat-item">
              <h4>100%</h4>
              <p>Sustainability Commitment</p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES CATALOGUE ===== -->
  <section class="section" id="services">
    <div class="container">
      <header class="section-header fade-in-up">
        <h2>Our Service Catalogue</h2>
        <p>Comprehensive end-to-end solutions that deliver real value. Transforming ideas into experiences, leveraging innovative technology, and championing sustainability.</p>
      </header>
      <div class="services-grid">
        {featuredServices.map((service, index) => (
          <ServiceCard
            title={service.data.title}
            description={service.data.description}
            icon={serviceIcons[service.id] ?? '⭐'}
            link={`/services/${service.id}`}
            class={`delay-${(index % 4) + 1}`}
          />
        ))}
      </div>
      <div class="section-cta fade-in-up">
        <a href="/services" class="btn btn-secondary">View Full Catalogue</a>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED PROJECTS ===== -->
  <section class="section" id="portfolio">
    <div class="container">
      <header class="section-header fade-in-up">
        <h2>Featured Projects</h2>
        <p>Discover how we bring ideas to life with flawless execution and innovative technology.</p>
      </header>
      <div class="projects-grid">
        {projects.map((project, index) => (
          <ProjectCard
            title={project.data.title}
            client={project.data.client}
            description={project.data.description}
            image={project.data.image}
            class={`delay-${(index % 4) + 1}`}
          />
        ))}
      </div>
      <div class="section-cta fade-in-up">
        <a href="/portfolio" class="btn btn-secondary">View All Work</a>
      </div>
    </div>
  </section>

  <!-- ===== CLIENTS ===== -->
  <Clients />

  <!-- ===== CTA BANNER ===== -->
  <section class="section" id="contact">
    <div class="container">
      <div class="cta-banner fade-in-up">
        <div class="cta-content">
          <h2 class="cta-title">Ready to elevate your brand?</h2>
          <p class="cta-subtitle">Let's discuss how our integrated solutions can transform your next project.</p>
          <a href="/contact" class="btn btn-primary">Get In Touch</a>
        </div>
        <div class="cta-glow"></div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Local layout overrides to match index.html exactly */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .about-visual {
    width: 100%;
    height: 420px;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.12), rgba(16, 185, 129, 0.12));
    border-radius: 28px;
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center; flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }
  .about-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 30%, rgba(59, 130, 246, 0.08), transparent 60%),
                radial-gradient(circle at 70% 70%, rgba(16, 185, 129, 0.08), transparent 60%);
  }
  .about-visual-icon { color: var(--primary-light); width: 64px; height: 64px; position: relative; z-index: 1; }
  .about-visual-label {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-main);
    position: relative; z-index: 1;
  }
  .about-text h2 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-heading);
    background: linear-gradient(135deg, var(--text-main), var(--primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .about-text p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .stat-item {
    background: var(--bg-surface);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    transition: all var(--trans-fast);
  }
  .stat-item h4 {
    font-size: 2.5rem;
    color: var(--primary-light);
    margin-bottom: 0.4rem;
    font-weight: 800;
  }
  .stat-item p { color: var(--text-muted); font-weight: 500; font-size: 0.9rem; margin: 0; }

  .services-grid, .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.75rem;
  }

  .section-cta {
    text-align: center;
    margin-top: 4rem;
  }

  /* CTA Banner */
  .cta-banner {
    position: relative;
    background: var(--bg-surface);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--border);
    border-radius: 28px;
    padding: 5rem 2rem;
    text-align: center;
    overflow: hidden;
  }
  .cta-content { position: relative; z-index: 2; }
  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #ffffff, var(--primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .cta-subtitle {
    color: var(--text-muted);
    font-size: 1.25rem;
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.15), transparent 70%);
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 1;
  }

  @media (max-width: 992px) {
    .about-grid { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>

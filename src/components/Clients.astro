---
const clients = [
  { name: 'Kerajaan Negeri Selangor', logo: 'https://thumbs.dreamstime.com/b/coat-arms-selangor-malaysia-coat-arms-selangor-malaysia-asian-267063097.jpg' },
  { name: 'MPKS - Majlis Perbandaran Kuala Selangor', logo: 'https://d2u1z1lopyfwlx.cloudfront.net/thumbnails/acc2ec63-f6d3-553b-8b9a-7c0e1689687a/3c026096-2a5e-5495-80b0-24d58ae3fad8.jpg' },
  { name: 'MBPJ - Majlis Bandaraya Petaling Jaya', logo: 'https://st.perplexity.ai/estatic/0b226c450798410ac541646c86ec31afd840e5beab817a5d84fa821e7db61981ec84c3b4a3f072a7a2e1899c9fb06c6ea3413cff4d3a6f1ed5e238052e8f919e2714637d2d19d1fab0b5f0a76075e3ac1c5e34f0f7fed10561b93af1c9e6b816' },
  { name: 'MPKL - Majlis Perbandaran Kuala Langat', logo: 'https://is1-ssl.mzstatic.com/image/thumb/Purple221/v4/03/f8/1c/03f81c00-961f-300e-68e3-ee300c2e6458/AppIcon-0-0-1x_U007emarketing-0-5-0-85-220.png/1200x630wa.png' },
  { name: 'Sime Darby UMW', logo: 'https://assets.nst.com.my/images/articles/simedarby-250823p21_NSTfield_image_socialmedia.var_1692932614.jpg' },
  { name: 'Cradle', logo: 'https://cdn.brandfetch.io/idvmLTTdta/w/400/h/400/theme/dark/icon.jpeg?c=1bxid64Mup7aczewSAYMX&t=1740285022114' },
  { name: 'Red Bull', logo: 'https://d2u1z1lopyfwlx.cloudfront.net/thumbnails/fad7242b-b42c-5f03-b60e-be2185a13f4e/ef7dcac2-2392-5df8-81de-a1c55e00577c.jpg' },
  { name: 'Astro', logo: 'https://cdn.prod.website-files.com/60a75d8226f3295ecacf9e33/6791b53f19f98fc141b8fc14_Astro%20Logo_Full%20Colour.png' },
 //{ name: 'DJ', logo: 'https://images.unsplash.com/photo-1571266028243-cb40fce750bd?auto=format&fit=crop&q=80&w=300' },
  { name: 'LBS Bina Group', logo: 'https://blwn.com.my/images/logos/logo-lbs-gray.png' },
  { name: 'Resorts World Genting', logo: 'https://matfa.org.my/wp-content/uploads/listing-uploads/logo/A9-GENTING-1.jpg' },
  { name: 'TAPAK Urban Street Dining', logo: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRgkrlNwkEoK0aZ3U-KDK8O8HUaug3ZmXtcfg&s' },
];
---

<section class="clients-section">
  <div class="clients-container">
    <div class="clients-header">
      <div class="section-label">Trusted By</div>
      <h2 class="section-title">Our Clients</h2>
      <p class="section-subtitle">
        A wide variety of business fields supporting everything from domestic life to industry.
      </p>
    </div>
    
    <div class="clients-grid">
      {clients.map(client => (
        <div class="client-card">
          <img 
            src={client.logo} 
            alt={`${client.name} Logo`} 
            class="client-logo"
            onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=300';"
            title={client.name}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .clients-section {
    background: rgba(30, 41, 59, 0.4);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 4rem 2rem;
  }

  .clients-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .clients-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .section-subtitle {
    color: var(--color-text-dim);
    font-size: 1rem;
  }

  .clients-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: center;
  }

  .client-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
  }

  .client-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(59, 130, 246, 0.12);
    transform: translateY(-3px);
  }

  .client-logo {
    height: 48px;
    width: auto;
    object-fit: contain;
    max-width: 140px;
    transition: transform 0.2s ease;
  }

  .client-card:hover .client-logo { transform: scale(1.05); }
</style>

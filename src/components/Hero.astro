---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  primaryCta?: { text: string; link: string };
  secondaryCta?: { text: string; link: string };
  badges?: string[];
}

const {
  eyebrow = 'Welcome to',
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  badges = [],
} = Astro.props;
---

<section class="hero">
  <!-- Subtle horizontal scanline shimmer (Sentinel AI aesthetic) -->
  <div class="hero-scanline" aria-hidden="true"></div>

  <div class="container hero-container">
    <div class="hero-content">
      <!-- Badge -->
      <div class="hero-badge fade-in-up">
        <span class="hero-badge-dot"></span>
        {eyebrow || "Malaysia's Premier Creative Partner"}
      </div>

      <!-- Title -->
      <h1 class="hero-title fade-in-up delay-1">
        {title || "Elevating Brands through Creative Tech & Seamless Event Production"}
      </h1>

      <!-- Subtitle -->
      <p class="hero-subtitle fade-in-up delay-2">
        {subtitle || "AS Creative Solution & Resources — a leading integrated provider delivering immersive experiences across Malaysia."}
      </p>

      <!-- CTAs -->
      {(primaryCta || secondaryCta) && (
        <div class="hero-actions fade-in-up delay-3">
          {primaryCta && (
            <a href={primaryCta.link} class="btn btn-primary" aria-label={primaryCta.text}>
              {primaryCta.text}
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.link} class="btn btn-secondary" aria-label={secondaryCta.text}>
              {secondaryCta.text}
            </a>
          )}
        </div>
      )}

      <!-- Stats Bar (Conditional for Home) -->
      {badges.length > 0 && (
        <div class="hero-stats fade-in-up delay-4">
          <div class="hero-stat-item">
            <div class="hero-stat-number">20+</div>
            <div class="hero-stat-label">Years Experience</div>
          </div>
          <div class="hero-stat-item">
            <div class="hero-stat-number">4</div>
            <div class="hero-stat-label">Service Pillars</div>
          </div>
          <div class="hero-stat-item">
            <div class="hero-stat-number">100%</div>
            <div class="hero-stat-label">Sustainability</div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 6rem;
    background-image: url('/hero-bg.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    isolation: isolate;
  }

  /* Multi-layer dark overlay for legibility */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 15, 0.65) 0%,
      rgba(10, 10, 15, 0.45) 50%,
      rgba(10, 10, 15, 0.85) 100%
    );
    z-index: -1;
  }

  /* Vignette edges */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(10,10,15,0.7) 100%);
    z-index: -1;
  }

  /* Scanline animation */
  @keyframes scanline {
    0%   { transform: translate3d(0, -100%, 0); opacity: 0; }
    10%  { opacity: 0.04; }
    90%  { opacity: 0.04; }
    100% { transform: translate3d(0, 100vh, 0); opacity: 0; }
  }
  .hero-scanline {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    backface-visibility: hidden;
  }
  .hero-scanline::before {
    content: '';
    position: absolute;
    left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--primary-light), transparent);
    animation: scanline 8s linear infinite;
    will-change: transform;
  }

  .hero-container { position: relative; z-index: 1; width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  .hero-content {
    text-align: center;
    max-width: 950px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1.2rem;
    background: rgba(59, 130, 246, 0.15);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--primary-light);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 2rem;
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    transform: translate3d(0, 0, 0);
  }

  .hero-badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--secondary);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.08;
    background: linear-gradient(135deg, #ffffff 0%, rgba(248, 250, 252, 0.9) 40%, var(--primary-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.5px;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: rgba(248, 250, 252, 0.72);
    margin-bottom: 3rem;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .hero-stat-item { text-align: center; }

  .hero-stat-number {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--text-main), var(--primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
    letter-spacing: 0.5px;
  }

  /* Fade-in animations */
  .hero .fade-in-up {
    animation: heroFadeIn 1s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
    transform: translateY(28px);
  }
  @keyframes heroFadeIn {
    to { opacity: 1; transform: translateY(0); }
  }
  .hero .fade-in-up.delay-1 { animation-delay: 0.15s; }
  .hero .fade-in-up.delay-2 { animation-delay: 0.3s; }
  .hero .fade-in-up.delay-3 { animation-delay: 0.45s; }
  .hero .fade-in-up.delay-4 { animation-delay: 0.6s; }

  @media (max-width: 768px) {
    .hero-title { font-size: 2.4rem; }
    .hero-actions { flex-direction: column; width: 100%; align-items: center; }
    .hero-actions .btn { width: 100%; max-width: 320px; }
    .hero-stats { flex-direction: column; gap: 1.5rem; padding-top: 2rem; margin-top: 3rem; }
  }
</style>

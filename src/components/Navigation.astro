---
// Navigation component - Floating glassmorphism navbar for AS Creative
const currentPath = Astro.url.pathname;
---

<header class="navbar" id="mainNav">
  <div class="container nav-container">
    <a href="/" class="logo" aria-label="ASCREATIVE Home">
      <i data-lucide="layers" class="logo-icon" aria-hidden="true"></i>
      <span>ASCREATIVE</span>
    </a>
    <nav class="nav-links" aria-label="Main Navigation" id="navLinks">
      <a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a>
      <a href="/about" class:list={[{ active: currentPath === '/about' }]}>About Us</a>
      <a href="/services" class:list={[{ active: currentPath.startsWith('/services') }]}>Services</a>
      <a href="/portfolio" class:list={[{ active: currentPath === '/portfolio' }]}>Portfolio</a>
      <a href="/contact" class:list={[{ active: currentPath === '/contact' }]}>Contact</a>
    </nav>
    <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle mobile menu" aria-expanded="false">
      <i data-lucide="menu" aria-hidden="true"></i>
    </button>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0; left: 0; width: 100%;
    z-index: 100;
    padding: 1.5rem 0;
    transition: all var(--trans-fast);
  }

  .navbar.scrolled {
    padding: 1rem 0;
    background: rgba(10, 10, 15, 0.75);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 4px 24px rgba(0,0,0,0.4);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .logo {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: var(--font-heading); font-size: 1.5rem;
    font-weight: 800; color: var(--text-main); letter-spacing: 1.5px;
    text-decoration: none;
  }

  .logo-icon { color: var(--primary); }

  .nav-links { display: flex; gap: 2.25rem; }

  .nav-links a {
    font-weight: 500; font-size: 0.9rem;
    color: rgba(248, 250, 252, 0.75);
    letter-spacing: 0.3px;
    position: relative;
    text-decoration: none;
    transition: color var(--trans-fast);
  }

  .nav-links a::after {
    content: '';
    position: absolute; bottom: -4px; left: 0;
    width: 0; height: 2px;
    background: var(--primary);
    transition: width var(--trans-fast);
    border-radius: 2px;
  }

  .nav-links a:hover, .nav-links a.active { color: var(--text-main); }
  .nav-links a:hover::after, .nav-links a.active::after { width: 100%; }

  .mobile-menu-btn {
    display: none; background: none; border: none;
    color: var(--text-main); cursor: pointer;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none; position: absolute; top: 100%; left: 0; width: 100%;
      background: rgba(10, 10, 15, 0.95); backdrop-filter: var(--glass-blur);
      flex-direction: column; padding: 2rem; border-bottom: 1px solid var(--border);
      gap: 1.5rem;
    }
    .nav-links.active { display: flex; }
    .mobile-menu-btn { display: block; }
  }
</style>

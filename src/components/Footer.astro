<footer>
  <div class="container footer-container">
    <div class="footer-brand">
      <a href="#" class="logo">
        <i data-lucide="layers" class="logo-icon"></i>
        <span>ASCREATIVE</span>
      </a>
      <p>Where Creativity, Technology, Events, and Sustainability Come Together. Delivering immersive experiences for over 20 years.</p>
    </div>
    
    <div class="footer-links">
      <div class="link-group">
        <h4>Navigation</h4>
        <a href="/">Home</a>
        <a href="/about">About Us</a>
        <a href="/services">Services</a>
        <a href="/portfolio">Portfolio</a>
        <a href="/contact">Contact</a>
      </div>
      
      <div class="link-group">
        <h4>Contact Info</h4>
        <a href="mailto:Adam.ascsr@gmail.com">Adam.ascsr@gmail.com</a>
        <a href="tel:+60173746240">+60 17-374 6240</a>
        <p style="color: var(--text-muted); font-size: 0.85rem; margin-top: 1rem;">
          Lot 14, Jalan Perusahaan Dua,<br/>
          Batu Caves Industrial Area,<br/>
          68100 Batu Caves, Selangor, Malaysia
        </p>
      </div>
    </div>
  </div>
  
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} AS Creative Solution & Resources. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding-top: 4rem;
    background: var(--bg-base);
    position: relative;
    z-index: 10;
  }
  
  .footer-container {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }
  
  .footer-brand .logo {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: var(--font-heading); font-size: 1.5rem;
    font-weight: 800; color: var(--text-main); letter-spacing: 1.5px;
    margin-bottom: 1.5rem;
  }
  
  .logo-icon { color: var(--primary); }
  
  .footer-brand p {
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 400px;
  }
  
  .footer-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  
  .link-group h4 {
    font-family: var(--font-heading);
    color: var(--text-main);
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
    font-weight: 600;
  }
  
  .link-group a {
    display: block;
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
    transition: color var(--trans-fast);
  }
  
  .link-group a:hover {
    color: var(--primary-light);
  }
  
  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  @media (max-width: 992px) {
    .footer-container { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
